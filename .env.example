# Copia este archivo a ".env" y pega tu clave real de Claude.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).
# Genera la clave en: https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-pega-aqui-tu-clave

# Modelo a usar por el "cerebro" (opcional; este es el valor por defecto)
ANTHROPIC_MODEL=claude-opus-4-8

# Contraseña de acceso a la app (opcional en local; OBLIGATORIA en el servidor).
# Si está vacía o no existe, la app no pide contraseña (solo recomendable en local).
APP_PASSWORD=
